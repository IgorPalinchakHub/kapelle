{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kapelle.dev/schemas/kapelle.config.schema.json",
  "title": "Kapelle application config (.claude/kapelle.config.json)",
  "description": "Minimal SDLC configuration. Project capabilities and knowledge providers are discovered natively by Claude Code and are not registered here.",
  "type": "object",
  "additionalProperties": false,
  "required": ["application"],
  "properties": {
    "//": { "type": "string" },
    "application": { "type": "string", "minLength": 1 },
    "artifact_root": {
      "type": "string",
      "minLength": 1,
      "default": "docs/features",
      "description": "Project-relative root for durable feature artifacts."
    },
    "modules": {
      "type": "array",
      "description": "Optional module boundaries used only as task context, never for capability routing.",
      "items": { "$ref": "#/$defs/module" }
    },
    "guidance_evidence": {
      "type": "string",
      "enum": ["required", "optional", "disabled"],
      "default": "optional",
      "description": "Whether implementation tasks must report project-guidance evidence. Kapelle does not prescribe how guidance is obtained."
    },
    "implementation": {
      "type": "object",
      "additionalProperties": false,
      "description": "Generic execution settings. Agent-team mode remains subject to runtime availability, explicit user approval, and safe task partitioning.",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["sequential", "agent-team"],
          "default": "sequential"
        },
        "max_parallel_agents": {
          "type": "integer",
          "minimum": 1,
          "maximum": 8,
          "default": 3
        },
        "approval_policy": {
          "type": "string",
          "enum": ["always", "risk-based", "never"],
          "default": "risk-based"
        },
        "max_task_attempts": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "default": 3
        },
        "max_agent_runs_per_task": {
          "type": "integer",
          "minimum": 3,
          "maximum": 20,
          "default": 8
        },
        "telemetry": {
          "type": "boolean",
          "default": true
        }
      },
      "default": {
        "mode": "sequential",
        "max_parallel_agents": 3,
        "approval_policy": "risk-based",
        "max_task_attempts": 3,
        "max_agent_runs_per_task": 8,
        "telemetry": true
      }
    }
  },
  "$defs": {
    "module": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path"],
      "properties": {
        "//": { "type": "string" },
        "id": { "type": "string", "minLength": 1 },
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "Path prefix used to provide module context."
        }
      }
    }
  }
}
