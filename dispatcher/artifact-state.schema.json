{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kapelle.dev/schemas/artifact-state.schema.json",
  "title": "Kapelle artifact lineage state",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact", "revision", "fingerprint", "based_on", "status"],
  "properties": {
    "artifact": { "type": "string", "minLength": 1 },
    "revision": { "type": "integer", "minimum": 1 },
    "fingerprint": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "based_on": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^sha256:[a-f0-9]{64}$"
      }
    },
    "status": {
      "type": "string",
      "enum": ["current", "review-required", "stale", "superseded"]
    }
  }
}
