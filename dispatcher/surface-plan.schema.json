{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kapelle.dev/schemas/surface-plan.schema.json",
  "title": "Kapelle feature aspect and integration plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["slug", "aspects", "contracts", "integration_checks"],
  "properties": {
    "slug": { "type": "string", "minLength": 1 },
    "aspects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "intent", "modules", "entrypoints", "depends_on"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "intent": { "type": "string", "minLength": 1 },
          "modules": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "entrypoints": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "depends_on": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          }
        }
      }
    },
    "contracts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "provider_aspect", "consumer_aspects", "artifact"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "provider_aspect": { "type": "string", "minLength": 1 },
          "consumer_aspects": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "artifact": { "type": "string", "minLength": 1 }
        }
      }
    },
    "integration_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "aspects", "intent", "validation"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "aspects": {
            "type": "array",
            "minItems": 2,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "intent": { "type": "string", "minLength": 1 },
          "validation": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
