{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kapelle.dev/schemas/change-revision.schema.json",
  "title": "Kapelle immutable change revision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "revision",
    "parent_revision",
    "amendment",
    "requirement_delta",
    "architecture_delta",
    "constraint_delta",
    "impacted_acceptance_criteria",
    "artifact_impacts",
    "route",
    "approval",
    "status"
  ],
  "properties": {
    "revision": { "type": "integer", "minimum": 1 },
    "parent_revision": { "type": ["integer", "null"], "minimum": 1 },
    "amendment": { "type": "string", "minLength": 1 },
    "requirement_delta": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "architecture_delta": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "constraint_delta": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "impacted_acceptance_criteria": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "artifact_impacts": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "enum": ["none", "review", "update", "stale", "superseded"]
      }
    },
    "route": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "approval": {
      "type": "string",
      "enum": ["pending", "approved", "rejected"]
    },
    "status": {
      "type": "string",
      "enum": ["draft", "reconciling", "approved", "superseded"]
    }
  }
}
