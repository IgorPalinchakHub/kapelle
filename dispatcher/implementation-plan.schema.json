{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kapelle.dev/schemas/implementation-plan.schema.json",
  "title": "Kapelle implementation plan lineage",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "change_id",
    "revision",
    "based_on",
    "strategy_path",
    "plan_path",
    "status"
  ],
  "properties": {
    "task_id": { "type": "string", "minLength": 1 },
    "change_id": { "type": ["string", "null"] },
    "revision": { "type": ["integer", "null"], "minimum": 1 },
    "based_on": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^sha256:[a-f0-9]{64}$"
      }
    },
    "strategy_path": { "type": "string", "minLength": 1 },
    "plan_path": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["draft", "approved", "stale", "superseded"]
    }
  }
}
