{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kapelle.dev/schemas/test-strategy.schema.json",
  "title": "Kapelle task test strategy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "task_class",
    "strategy",
    "rationale",
    "invariants",
    "scenarios",
    "validation"
  ],
  "properties": {
    "task_id": { "type": "string", "minLength": 1 },
    "task_class": {
      "type": "string",
      "enum": [
        "bugfix",
        "isolated-behavior",
        "legacy-change",
        "refactor",
        "complex-domain",
        "contract-boundary",
        "migration-config",
        "non-code"
      ]
    },
    "strategy": {
      "type": "string",
      "enum": [
        "strict-tdd",
        "characterization",
        "scenario-first",
        "contract-first",
        "validation-first",
        "validation-only"
      ]
    },
    "rationale": { "type": "string", "minLength": 1 },
    "invariants": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "scenarios": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "validation": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "unresolved": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    }
  }
}
