{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kapelle.dev/schemas/change-request.schema.json",
  "title": "Kapelle existing-feature change request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "change_id",
    "feature_slug",
    "mode",
    "description",
    "current_revision",
    "active_state_path",
    "baseline",
    "impacted_acceptance_criteria",
    "artifact_impacts",
    "route",
    "approval",
    "status"
  ],
  "properties": {
    "change_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "maxLength": 64
    },
    "feature_slug": { "type": "string", "minLength": 1 },
    "mode": {
      "type": "string",
      "enum": ["bugfix", "enhancement", "refactor"]
    },
    "description": { "type": "string", "minLength": 1 },
    "current_revision": { "type": "integer", "minimum": 1 },
    "active_state_path": { "type": "string", "minLength": 1 },
    "baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observed_behavior", "artifact_snapshots", "code_evidence"],
      "properties": {
        "observed_behavior": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "artifact_snapshots": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "code_evidence": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "impacted_acceptance_criteria": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "artifact_impacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "spec",
        "design",
        "surface_plan",
        "sequences",
        "data_model",
        "contracts",
        "test_plan",
        "tasks"
      ],
      "properties": {
        "spec": { "$ref": "#/$defs/impact" },
        "design": { "$ref": "#/$defs/impact" },
        "surface_plan": { "$ref": "#/$defs/impact" },
        "sequences": { "$ref": "#/$defs/impact" },
        "data_model": { "$ref": "#/$defs/impact" },
        "contracts": { "$ref": "#/$defs/impact" },
        "test_plan": { "$ref": "#/$defs/impact" },
        "tasks": { "$ref": "#/$defs/impact" }
      }
    },
    "route": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "specify",
          "clarify",
          "design",
          "decide-adr",
          "sequences",
          "data-model",
          "contracts",
          "tasks",
          "plan-tests",
          "implement",
          "review",
          "ship"
        ]
      }
    },
    "risks": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "approval": {
      "type": "string",
      "enum": ["pending", "approved", "rejected"]
    },
    "status": {
      "type": "string",
      "enum": ["assessed", "in-progress", "blocked", "completed"]
    }
  },
  "$defs": {
    "impact": {
      "type": "string",
      "enum": ["none", "review", "update"]
    }
  }
}
