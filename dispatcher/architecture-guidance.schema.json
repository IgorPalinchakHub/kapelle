{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kapelle.dev/schemas/architecture-guidance.schema.json",
  "title": "Scoped project architecture guidance",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "capability", "scope", "rules", "sources", "gaps"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["ARCHITECTURE_GUIDANCE_READY", "BLOCKED"]
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "kind"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "kind": { "const": "project-subagent" }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["aspects", "modules", "entrypoints", "paths"],
      "properties": {
        "aspects": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "modules": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "entrypoints": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "paths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "summary", "source"],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 }
        }
      }
    },
    "sources": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "gaps": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
